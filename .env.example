# =============================================================================
# Database (Neon)
# =============================================================================
# Use the POOLED connection string from Neon dashboard
# Format: postgresql://user:pass@ep-xxx-pooler.region.neon.tech/dbname?sslmode=require
DATABASE_URL=

# =============================================================================
# Auth (Better-Auth)
# =============================================================================
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public URL of your app (no trailing slash)
BETTER_AUTH_URL=http://localhost:3000

# =============================================================================
# Storage (Cloudflare R2) — optional, fill when you need uploads
# =============================================================================
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_URL=

# =============================================================================
# Email (Resend) — optional, fill when you need transactional email
# =============================================================================
RESEND_API_KEY=
EMAIL_FROM=

# =============================================================================
# Google Maps Places API — optional, only required for /spin "Near me" mode
# =============================================================================
# 1. Google Cloud Console → enable "Places API (New)"
# 2. APIs & Services → Credentials → create an API key
# 3. Restrict it to the Places API only (server-side use, so no referrer needed)
GOOGLE_MAPS_API_KEY=
